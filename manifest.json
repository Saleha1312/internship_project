{
  "manifest_version": 3,
  "name": "Real-Time Page Data Extractor",
  "version": "1.1",
  "permissions": ["activeTab", "scripting", "tabs"],
  "host_permissions": [
    "http://localhost:8000/*", "https://www.site24x7.eu/app/client#/home/monitors"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost:8000/*", "https://www.site24x7.eu/app/client#/home/monitors"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}